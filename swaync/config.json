{
  "$schema": "/etc/xdg/xdg-arch/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "cssPriority": "application",
  "notification-icon-size": 32,
  "timeout": 10,
  "timeout-low": 5,
  "timeout-critical": 0,
  "notification-window-width": 350,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "hide-on-action": true,
  "hide-on-clear": false,
  "widgets": [
    "title",
    "dnd",
    "notifications",
    "mpris"
  ]
}
